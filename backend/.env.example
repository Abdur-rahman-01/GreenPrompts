# GreenPrompt Backend — Environment Variables
# Copy this file to .env and fill in your real keys (never commit .env)

# Required — Groq inference API (https://console.groq.com)
GROQ_API_KEY=gsk_...

# Required — Google Gemini API for classification + ultimate fallback (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=AIza...

# Optional — Electricity Maps for real-time carbon intensity (https://api.electricitymap.org)
ELECTRICITY_MAPS_API_KEY=your_key_here
